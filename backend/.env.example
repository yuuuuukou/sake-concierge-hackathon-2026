# Azure / Foundry
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_AIPROJECT_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_NAME=

# Pre-created Agent values from backend/scripts/setup_agent.py
AZURE_AGENT_NAME=
AZURE_AGENT_VERSION=
AZURE_BRAND_RESEARCH_AGENT_NAME=
AZURE_BRAND_RESEARCH_AGENT_VERSION=

# Store data. Production should use blob; local demo uses masked local fixtures.
STORE_DATA_SOURCE=local
STORE_DATA_ROOT=src/data/stores
STORE_DATA_STORE_IDS=fukunotomo
STORE_DATA_REQUIRED_FILES=catalog_master.csv,sku_simplified.csv,catalog.md,brewery.md

# For production, set STORE_DATA_SOURCE=blob and fill the private Blob settings below.
STORE_DATA_CACHE_ROOT=
STORE_DATA_BLOB_ACCOUNT_NAME=
STORE_DATA_BLOB_ACCOUNT_URL=
STORE_DATA_BLOB_CONTAINER=store-data
STORE_DATA_BLOB_PREFIX=stores

# Public runtime guards
PUBLIC_BASE_URL=
A2A_API_KEY=
CHAT_RATE_LIMIT_PER_MINUTE=5
CHAT_RATE_LIMIT_WINDOW_SECONDS=60
EVENT_RATE_LIMIT_PER_MINUTE=60
EVENT_RATE_LIMIT_WINDOW_SECONDS=60
CHAT_TEXT_CAPTURE_MODE=feedback_only
SESSION_HASH_SALT=
TRUST_FORWARDED_HEADERS=false
BRAND_RESEARCH_TOOL_CHOICE_MODE=intent

